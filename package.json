{
  "name": "qwen-os",
  "version": "1.0.0",
  "description": "Unified Qwen Operating System - OOP agent orchestration platform",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "tsc --build tsconfig.build.json",
    "dev": "bun run --filter '*' dev",
    "start": "bun run apps/cli/src/cli.ts",
    "qos": "bun run apps/cli/src/cli.ts",
    "test": "bun test",
    "lint": "bunx tsc --noEmit",
    "clean": "rm -rf dist packages/*/dist apps/*/dist"
  },
  "keywords": ["ai", "agent", "orchestration", "mcp", "swarm"],
  "license": "MIT",
  "dependencies": {
    "zod": "^3.24.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "bun": ">=1.0.0"
  }
}
